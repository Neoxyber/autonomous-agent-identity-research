{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Neoxyber/autonomous-agent-identity-research/specs/agent-passport.schema.json",
  "title": "Agent Passport Envelope",
  "type": "object",
  "required": [
    "passport",
    "proofs"
  ],
  "additionalProperties": false,
  "properties": {
    "passport": {
      "type": "object",
      "required": [
        "passport_id",
        "agent_id",
        "operator",
        "issuer_id",
        "subject",
        "purpose",
        "risk_class",
        "public_keys",
        "issued_at",
        "expires_at",
        "lifecycle_status",
        "permissions",
        "revocation",
        "audit"
      ],
      "additionalProperties": false,
      "properties": {
        "passport_id": {
          "$ref": "#/$defs/aaid"
        },
        "agent_id": {
          "$ref": "#/$defs/aaid"
        },
        "operator": {
          "$ref": "#/$defs/operator"
        },
        "issuer_id": {
          "$ref": "#/$defs/aaid"
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "risk_class": {
          "type": "string",
          "enum": [
            "low",
            "standard",
            "elevated",
            "high"
          ]
        },
        "public_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/public_key"
          }
        },
        "issued_at": {
          "$ref": "#/$defs/timestamp"
        },
        "expires_at": {
          "$ref": "#/$defs/timestamp"
        },
        "lifecycle_status": {
          "type": "string",
          "enum": [
            "active",
            "suspended",
            "revoked",
            "expired",
            "compromised",
            "retired"
          ]
        },
        "permissions": {
          "$ref": "#/$defs/permissions"
        },
        "revocation": {
          "$ref": "#/$defs/revocation"
        },
        "audit": {
          "$ref": "#/$defs/audit_reference"
        }
      }
    },
    "proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proof"
      }
    }
  },
  "$defs": {
    "aaid": {
      "type": "string",
      "pattern": "^urn:aaid:[a-z][a-z0-9-]{1,40}:[A-Za-z0-9._:-]{1,200}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "base64url": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "hash_hex": {
      "type": "string",
      "pattern": "^([a-f0-9]{64}|[a-f0-9]{96}|[a-f0-9]{128})$"
    },
    "operator": {
      "type": "object",
      "required": [
        "operator_id",
        "operator_type",
        "verification_status"
      ],
      "additionalProperties": false,
      "properties": {
        "operator_id": {
          "$ref": "#/$defs/aaid"
        },
        "operator_type": {
          "type": "string",
          "enum": [
            "person",
            "legal_entity",
            "research_demo"
          ]
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "declared",
            "demo_verified",
            "pending_review",
            "rejected",
            "revoked"
          ]
        },
        "verification_method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "verification_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "public_key": {
      "type": "object",
      "required": [
        "kid",
        "kty",
        "alg",
        "purpose",
        "public_key_b64u",
        "created_at",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "kid": {
          "$ref": "#/$defs/aaid"
        },
        "kty": {
          "type": "string",
          "minLength": 2,
          "maxLength": 60
        },
        "alg": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "purpose": {
          "type": "string",
          "enum": [
            "sig",
            "verify",
            "hybrid-sig"
          ]
        },
        "public_key_b64u": {
          "$ref": "#/$defs/base64url"
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "not_after": {
          "$ref": "#/$defs/timestamp"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "retired",
            "compromised"
          ]
        }
      }
    },
    "permissions": {
      "type": "object",
      "required": [
        "allowed_actions",
        "approval_required_actions",
        "prohibited_actions",
        "default_decision"
      ],
      "additionalProperties": false,
      "properties": {
        "allowed_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_scope"
          }
        },
        "approval_required_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_scope"
          }
        },
        "prohibited_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_scope"
          }
        },
        "default_decision": {
          "const": "DENY"
        },
        "policy_id": {
          "$ref": "#/$defs/aaid"
        }
      }
    },
    "action_scope": {
      "type": "object",
      "required": [
        "action",
        "resource_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,80}$"
        },
        "resource_scope": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "revocation": {
      "type": "object",
      "required": [
        "method",
        "status_reference"
      ],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "signed_status_reference",
            "signed_revocation_list",
            "issuer_status_endpoint"
          ]
        },
        "status_reference": {
          "$ref": "#/$defs/aaid"
        }
      }
    },
    "audit_reference": {
      "type": "object",
      "required": [
        "audit_required",
        "audit_stream_id"
      ],
      "additionalProperties": false,
      "properties": {
        "audit_required": {
          "const": true
        },
        "audit_stream_id": {
          "$ref": "#/$defs/aaid"
        }
      }
    },
    "proof": {
      "type": "object",
      "required": [
        "proof_id",
        "proof_type",
        "proof_purpose",
        "verification_method",
        "alg",
        "kid",
        "canonicalization",
        "hash_alg",
        "payload_hash",
        "signature_b64u",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "proof_id": {
          "$ref": "#/$defs/aaid"
        },
        "proof_type": {
          "type": "string",
          "enum": [
            "detached-signature"
          ]
        },
        "proof_purpose": {
          "type": "string",
          "enum": [
            "passport-signature",
            "transition-signature",
            "post-quantum-signature"
          ]
        },
        "verification_method": {
          "$ref": "#/$defs/aaid"
        },
        "alg": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "kid": {
          "$ref": "#/$defs/aaid"
        },
        "canonicalization": {
          "type": "string",
          "enum": [
            "json-canonicalization-scheme"
          ]
        },
        "hash_alg": {
          "type": "string",
          "enum": [
            "SHA-256",
            "SHA-384",
            "SHA-512"
          ]
        },
        "payload_hash": {
          "$ref": "#/$defs/hash_hex"
        },
        "signature_b64u": {
          "$ref": "#/$defs/base64url"
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    }
  }
}
